@startuml US07_Placar_Tempo
start
:Uma passagem é confirmada\n(pagou com a tag);
partition "Tempo economizado" {
  :O sistema pega o tempo médio\nna fila do pedágio manual;
  :O sistema pega o tempo\nde passar direto com a tag;
  :Calcula quanto tempo\nessa passagem economizou;
